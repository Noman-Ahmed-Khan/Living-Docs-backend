# Application
APP_NAME=LivingDocs
DEBUG=true

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=livingdocs
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB
# For SQLite (local dev): DATABASE_URL=sqlite:///./livingdocs.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800


PROJECT_NAME=Talk Docs
FRONTEND_URL=http://localhost:3000
DEBUG=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (Gmail example - use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LivingDocs
SMTP_TLS=true


# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_ENVIRONMENT=gcp-starter

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HUGGINGFACE_LLM_MODEL=bigscience/bloom-560m
HUGGINGFACE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# HUGGINGFACE_LLM_MODEL=HuggingFaceH4/zephyr-7b-beta
HUGGINGFACE_LLM_PROVIDER=

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# JWT
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=10080


# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
REQUIRE_EMAIL_VERIFICATION=True


# Token Expiration
VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# RAG PIPELINE SETTINGS (Optional Defaults)
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_TOP_K=5
DEFAULT_RETRIEVAL_STRATEGY="mmr"  # similarity, mmr, hybrid


# CORS SETTINGS
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"